{
  "name": "@momentlog/domain",
  "version": "0.0.0",
  "private": true,
  "description": "Pure domain layer for MomentLog — runtime-agnostic (Node/Deno/RN). Zero runtime dependencies.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./vlog": "./src/vlog/index.ts",
    "./slot": "./src/slot/index.ts",
    "./time": "./src/time/index.ts",
    "./shared": "./src/shared/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage *.tsbuildinfo"
  },
  "dependencies": {},
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.5.0"
  }
}
