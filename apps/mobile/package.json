{
  "name": "@momentlog/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "MomentLog mobile app — React Native + Expo SDK 52 + Feature-Sliced Design",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'app/**/*.{ts,tsx}' 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .expo dist node_modules/.cache"
  },
  "dependencies": {
    "@momentlog/domain": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "typescript": "^5.5.0"
  }
}
